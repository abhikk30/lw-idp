{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":prConcurrentLimit10", ":timezone(America/Los_Angeles)"],
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "packageRules": [
    { "matchPackagePatterns": ["^@types/"], "groupName": "types packages", "automerge": true },
    {
      "matchDepTypes": ["devDependencies"],
      "groupName": "devDependencies",
      "schedule": ["before 9am on monday"]
    },
    { "matchUpdateTypes": ["patch"], "automerge": true }
  ]
}
