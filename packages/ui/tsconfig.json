{
  "extends": "@lw-idp/config/tsconfig",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
