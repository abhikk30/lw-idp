{
  "name": "@lw-idp/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./identity/v1": "./dist/proto/lwidp/identity/v1/identity_pb.ts",
    "./catalog/v1": "./dist/proto/lwidp/catalog/v1/catalog_pb.ts",
    "./cluster/v1": "./dist/proto/lwidp/cluster/v1/cluster_pb.ts"
  },
  "files": ["dist", "dist-ts", "openapi", "proto", "src"],
  "scripts": {
    "codegen": "buf generate",
    "lint": "buf lint",
    "breaking": "buf breaking --against '.git#branch=main'",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1"
  },
  "devDependencies": {
    "@lw-idp/config": "workspace:*",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "typescript": "catalog:"
  }
}
