.superpowers/
.DS_Store
node_modules/
dist/
build/
.env
.env.*
!.env.example
*.log
.idea/
.vscode/

# turbo
.turbo/

# test artifacts
coverage/
*.tsbuildinfo

# generated
# Guard against tsc accidentally emitting .js into app src/ directories when
# tsconfig.test.json is run with rootDir set above the app root.
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map

# Buf-generated .ts in packages/contracts/dist/proto/ IS committed (source of
# truth for TS consumers). Override the blanket `dist/` rule on line 4 to
# re-include this one dist tree, then exclude its compiled JS/maps/tsbuildinfo.
!packages/contracts/dist/
!packages/contracts/dist/**
packages/contracts/dist/**/*.js
packages/contracts/dist/**/*.js.map
packages/contracts/dist/**/*.tsbuildinfo
packages/contracts/src/**/*.js
packages/contracts/src/**/*.js.map
packages/contracts/test/**/*.js
packages/contracts/test/**/*.js.map
packages/contracts/dist-ts/

# env
.env.local
.env.*.local

# OS
Thumbs.db
