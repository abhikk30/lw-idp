# syntax=docker/dockerfile:1.7
# SOURCE-OF-TRUTH backend Dockerfile — do not edit per-service copies.
# Run `./scripts/sync-dockerfiles.sh --write` to propagate changes.
FROM node:22-alpine AS base
ARG SERVICE
ENV SERVICE=${SERVICE}
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages ./packages
COPY apps ./apps
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prefer-offline

FROM deps AS builder
# Build all workspace lib packages that backend services depend on
RUN pnpm --filter "@lw-idp/errors" \
        --filter "@lw-idp/telemetry" \
        --filter "@lw-idp/service-kit" \
        --filter "@lw-idp/auth" \
        --filter "@lw-idp/db" \
        --filter "@lw-idp/events" build
# contracts: proto .ts files already generated by buf; compile .js in-place (outDir=".")
RUN cd /repo/packages/contracts && \
    ./node_modules/.bin/tsc -p tsconfig.json
# Patch exports in each workspace lib so pnpm deploy bundles compiled JS
RUN apk add --no-cache jq && \
    for pkg in errors telemetry service-kit auth db events; do \
      pkgjson="/repo/packages/$pkg/package.json"; \
      jq '.exports = {".": "./dist/src/index.js"}' "$pkgjson" > /tmp/p.json && \
      mv /tmp/p.json "$pkgjson"; \
      echo "patched $pkg"; \
    done && \
    pkgjson="/repo/packages/contracts/package.json"; \
    jq '.exports = {".": "./src/index.js", "./identity/v1": "./dist/proto/lwidp/identity/v1/identity_pb.js", "./catalog/v1": "./dist/proto/lwidp/catalog/v1/catalog_pb.js", "./cluster/v1": "./dist/proto/lwidp/cluster/v1/cluster_pb.js"}' "$pkgjson" > /tmp/p.json && \
    mv /tmp/p.json "$pkgjson" && \
    echo "patched contracts"
# Build the service itself
RUN pnpm -F "./apps/${SERVICE}" build
# pnpm deploy creates a standalone directory with all prod deps resolved
RUN pnpm --filter "./apps/${SERVICE}" deploy --prod /deploy
# Verify the deploy includes the compiled contracts JS (pnpm hardlinks from the
# source builder stage). If missing — fail loud. Older Dockerfile versions did
# an explicit cp here; pnpm's default linker makes the deploy dir share inodes
# with source so that cp was redundant (and actually failed in CI with
# "are the same file").
RUN CONTRACTS_DEPLOY=$(find /deploy/node_modules -name "contracts" -type d 2>/dev/null | grep "@lw-idp/contracts$" | head -1) && \
    test -n "$CONTRACTS_DEPLOY" || { echo "ERROR: contracts deploy dir not found" >&2; exit 1; } && \
    test -f "$CONTRACTS_DEPLOY/src/index.js" || { echo "ERROR: $CONTRACTS_DEPLOY/src/index.js missing" >&2; exit 1; } && \
    test -f "$CONTRACTS_DEPLOY/dist/proto/lwidp/identity/v1/identity_pb.js" || { echo "ERROR: identity_pb.js missing in deploy" >&2; exit 1; } && \
    test -f "$CONTRACTS_DEPLOY/dist/proto/lwidp/catalog/v1/catalog_pb.js" || { echo "ERROR: catalog_pb.js missing in deploy" >&2; exit 1; } && \
    test -f "$CONTRACTS_DEPLOY/dist/proto/lwidp/cluster/v1/cluster_pb.js" || { echo "ERROR: cluster_pb.js missing in deploy" >&2; exit 1; } && \
    echo "contracts deploy OK at $CONTRACTS_DEPLOY"
# Ensure migrations dir exists so the COPY below is always valid (no-op for
# services that don't use DB migrations, e.g. gateway-svc).
RUN mkdir -p /repo/apps/${SERVICE}/src/db/migrations

FROM node:22-alpine AS runtime
ARG SERVICE
ENV SERVICE=${SERVICE}
ENV NODE_ENV=production
ENV PORT=4000
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --from=builder --chown=app:app /deploy/node_modules ./node_modules
COPY --from=builder --chown=app:app /repo/apps/${SERVICE}/dist ./dist
COPY --from=builder --chown=app:app /repo/apps/${SERVICE}/package.json ./package.json
COPY --from=builder --chown=app:app /repo/apps/${SERVICE}/src/db/migrations ./src/db/migrations
USER app
EXPOSE 4000
CMD ["node", "dist/src/index.js"]
