    "@lw-idp/service-kit": "workspace:*",
    "@lw-idp/telemetry": "workspace:*",
    "drizzle-orm": "0.36.0",
    "postgres": "3.4.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lw-idp/config": "workspace:*",
    "@lw-idp/testing": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.0",
    "pg": "8.13.0",
    "tsx": "4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
