{
  "extends": "@lw-idp/config/tsconfig",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["src", "test", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
